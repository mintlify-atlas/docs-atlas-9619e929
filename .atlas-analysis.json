  "keyFeatures": [
    "Multi-runtime support (Node.js, Deno, Bun, Cloudflare Workers, Vercel Edge)",
    "Retrieval-Augmented Generation (RAG) with vector stores",
    "Agent and workflow orchestration",
    "Modular provider system with 30+ integrations",
    "Chat and query engines for conversational AI",
    "Data ingestion pipelines with multiple readers",
    "Embedding and LLM abstraction layer",
    "Storage abstractions (vector, document, chat, KV stores)"
  ],
  "publicApiSurface": [
    "llamaindex - Main package with aggregated functionality",
    "@llamaindex/core - Base classes and interfaces",
    "@llamaindex/workflow - Workflow orchestration API",
    "@llamaindex/openai - OpenAI LLM and embeddings",
    "@llamaindex/anthropic - Anthropic Claude integration",
    "@llamaindex/ollama - Ollama local LLM support",
    "VectorStoreIndex - Primary vector-based index",
    "Settings - Global configuration management",
    "ChatEngine - Conversational interface",
    "QueryEngine - Document querying interface",
    "Document - Core document class",
    "SimpleNodeParser - Text chunking",
    "RetrieverQueryEngine - Query with retrieval",
    "CondenseQuestionChatEngine - Chat with context",
    "IngestionPipeline - Data processing pipeline"
  ]
